# DataAgent 环境变量配置模板，请复制此文件为 .env 并设置实际值。
# 约定：.env 仅放密钥/环境相关值；YAML 仅放 Agent 行为定义。
# YAML 中使用 $env{VAR_NAME} 显式引用环境变量。

# ===== LLM 平台配置 =====
# YAML 中 MODEL.*.provider 字段作为平台名，自动查找 {PROVIDER}_BASE_URL 和 {PROVIDER}_API_KEY。用的什么平台的就填什么平台，和模型无关
# 例如：provider: "deepseek" -> DEEPSEEK_BASE_URL + DEEPSEEK_API_KEY

# 日志配置
DATAAGENT_LOG_LEVEL="INFO"

# DeepSeek
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_API_KEY=""

BAILIAN_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
BAILIAN_API_KEY=""

OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_API_KEY=""

ANTHROPIC_BASE_URL="https://api.anthropic.com"
ANTHROPIC_API_KEY=""

# ===== Embedding 服务 （当使用Memory模块时需要配置）=====
EMBEDDING_BASE_URL=""
EMBEDDING_API_KEY=""

# ===== 数据源 =====
DATASOURCE_DATABASE_ADDRESS="mysql+pymysql://root:password@localhost:3306"

# ===== Memory 存储 =====
MEMORY_PATH_PREFIX=""
MEMORY_LONG_TERM_STORAGE_URL="http://username:password@localhost:9200" #ES数据库地址
MEMORY_SHORT_TERM_STORAGE_URL="postgresql+psycopg2://user:password@localhost:5432/langgraph"

# 注意：sqlite和pg二选一即可
# ===== Web 后端 sqlite数据库配置=====
DATABASE_URL="sqlite:///./datapilot.db"

# ===== Web 后端 Postgres数据库配置=====
DATABASE_HOST="localhost"
DATABASE_PORT="5432"
DATABASE_NAME="datapilot"
DATABASE_USER="datapilot_user"
DATABASE_PASSWORD="YOUR_PASSWORD"
DATABASE_URL="postgresql://datapilot_user:{YOUR_PASSWORD}@localhost:5432/datapilot"

# ===== Web 后端其他 =====
ENCRYPTION_KEY="" # 知识库处理PDF文件依赖的RAG_ANYTHING使用

# ===== 外部工具 =====
TAVILY_API_KEY="" # WebSearch(a2a)工具使用的apikey

# ===== 部署与代理 =====
DEPLOY_ZONE="internal" # 区分内部和外部环境
HTTP_PROXY="" # 内部部署时，执行MCP工具需要内部代理地址
NO_PROXY="" # 内部部署时，执行MCP工具需要配置不需要走代理的地址

# ===== 场景与本体（本地开发，示例：financial、bio_research、manufacturing）=====
SCENE="financial"
ONTOLOGY_URL="http://localhost:8000"

# 各场景yaml路径（仅本地开发使用）
# AGENT_CONFIG_PATH="...../dataagent/core/flex/examples/xxxx.yaml"